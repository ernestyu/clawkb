#!/usr/bin/env bash
# Lightweight shell front-end for clawkb.
#
# Goals:
# - Zero per-call environment exports for common settings.
# - Automatically load project .env when present.
# - Provide a simple `./clawkb_sh ingest <URL> [extra args...]` interface.
#
# This script assumes it lives in the Clawkb repo under `bin/`.

set -euo pipefail

# Resolve repo root as the parent directory of this script
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="${SCRIPT_DIR%/bin}"
cd "$REPO_ROOT"

# 1) Auto-load .env (if present) without overriding existing env vars
ENV_FILE="$REPO_ROOT/.env"
if [[ -f "$ENV_FILE" ]]; then
  # Read KEY=VALUE lines, ignore comments/blank, do not override existing vars
  while IFS= read -r line; do
    line="${line##+([[:space:]])}"
    # Skip empty or comment lines
    [[ -z "$line" || "$line" == \#* ]] && continue
    # Require KEY=VALUE format
    if [[ "$line" != *"="* ]]; then
      continue
    fi
    key="${line%%=*}"
    val="${line#*=}"
    key="${key%%+([[:space:]])}"
    key="${key##+([[:space:]])}"
    val="${val##+([[:space:]])}"
    val="${val%%+([[:space:]])}"
    [[ -z "$key" ]] && continue
    # Strip optional quotes around value
    if [[ ("$val" == \"*\" && "$val" == *\") || ("$val" == "'*" && "$val" == *"'") ]]; then
      val="${val:1:${#val}-2}"
    fi
    # Only set if not already in environment
    if [[ -z "${!key-}" ]]; then
      export "$key"="$val"
    fi
  done <"$ENV_FILE"
fi

# 2) Ensure PYTHONPATH points to the repo's Python package (if using src layout)
# In this repo layout, the Python package lives under ./clawkb/
export PYTHONPATH="${PYTHONPATH:-}:$REPO_ROOT"

# 3) Default root for data if not overridden by env
export CLAWKB_ROOT_DEFAULT="${CLAWKB_ROOT_DEFAULT:-$REPO_ROOT/clawkb_data}"

# 4) Dispatch into the Python CLI
#    Usage examples:
#      ./clawkb_sh ingest --url "https://example.com" --category "blog" --json
#      ./clawkb_sh search --query "OpenClaw"

exec /opt/venv/bin/python -m clawkb.cli "$@"
